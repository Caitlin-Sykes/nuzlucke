		jsonb qol_features  "Challenge Modes, HM Items, etc"  
		varchar(50) difficulty_level  ""  
		bool unique_story  "DEFAULT TRUE"  
	}

	TYPES["&nbsp&nbsp&nbsp&nbsp&nbsp&nbsp&nbsp&nbsp&nbsp&nbsp&nbsp&nbsp&nbsp&nbspTYPES<br>All possible Pokemon Types"] {
		serial id  "PK"  
		VARCHAR(50) name  "UNIQUE NOT NULL"  
		BOOLEAN is_official  "DEFAULT TRUE"  
	}

	POKEMON["POKEMON<br> All pokemon and their base data"] {
		serial id  "PK"  
		int national_dex_number  "NOT NULL"  
		varchar(50) name  "NOT NULL"  
		varchar(50) slug  "DEFAULT NULL"  
		varchar(50) form_name  "DEFAULT NULL"  
		bool is_official_form  "DEFAULT TRUE"  
		int evolves_from_id  "FK - SELF-REFERENCING "  
		UNIQUE_CONSTRAINT dex_and_form_name  "UNIQUE (national_dex_number, form_name)"  
		INDEX idx_pokemon_evolves_from  "pokemon(evolves_from_id)"  
	}

	POKEMON_GAME_STATS["POKEMON_GAME_STATS<br>&nbsp&nbspVariable Pokemon Stats"] {
		serial id  "PK"  
		int pokemon_id  "NOT NULL REFERENCES pokemon(id)"  
		int ruleset_id  "NOT NULL REFERENCES rulesets(id)"  
		int type_1_id  "REFERENCES types(id)"  
		int type_2_id  "REFERENCES types(id)"  
		int ability_1_id  "REFERENCES abilities(id)"  
		int ability_2_id  "REFERENCES abilities(id)"  
		int hidden_ability_id  "REFERENCES abilities(id)"  
		UNIQUE_CONSTRAINT unique_pokemon_per_ruleset  "UNIQUE (pokemon_id, ruleset_id)"  
	}

	SYNC_STATE["&nbsp&nbsp&nbsp&nbspSYNC_STATE<br/>&nbspTracks data import<br/>&nbsp&nbsp&nbspstatus & history"] {
		text component  "PK, NOT NULL"  
		int generation  "PK, NOT NULL"  
		sync_status status  "NOT NULL, ENUM: 'completed', 'failed', 'in_progress'"  
		timestamptz started_at  "NOT NULL, DEFAULT now()"  
		timestamptz finished_at  "NULLABLE"  
		jsonb last_cursor  "NULLABLE"  
		text run_config_hash  "NULLABLE"  
		text error_message  "NULLABLE"  
		UNIQUE_CONSTRAINT sync_state_pk  "PRIMARY KEY (component, generation)"  
	}

	LOCATIONS["&nbsp&nbsp&nbsp&nbspLOCATIONS<br/>Represents broad <br/>geographical areas"] {
		serial id  "PK"  
		int region_id  "FK"  
		varchar(100) name  "NOT NULL"  
		UNIQUE_CONSTRAINT unique_loc_per_region  "UNIQUE (region_id, name)"  
	}

	LOCATION_AREAS["LOCATION_AREAS<br/>Represents specific <br/>sub-sections within <br/>&nbsp&nbsp&nbsp&nbsp&nbsp&nbsp&nbsp&nbspa Location"] {
		serial id  "PK"  
		int location_id  "NOT NULL REFERENCES locations(id)"  
		varchar(100) name  "NOT NULL"  
		UNIQUE_CONSTRAINT unique_area_per_location "UNIQUE (name, location_id)"
	}

	MILESTONES["&nbsp&nbsp&nbsp&nbsp&nbsp&nbsp&nbsp&nbsp&nbspMILESTONES<br/>Represents certain stages of the game."] {
		serial id "PK"
        int game_id "REFERENCES games(id)"
        varchar(100) stage_name "NOT NULL"
        int level_cap "NOT NULL"
        int order_index "NOT NULL"
        varchar(50) game_slug
        varchar(50) unlocks_surf "BOOLEAN DEFAULT FALSE"
        varchar(50) has_fishing_rod "BOOLEAN DEFAULT FALSE"
        UNIQUE_CONSTRAINT uq_game_order_index "UNIQUE(game_id, order_index)"
	}

		MILESTONES_TRAINER["&nbsp&nbsp&nbsp&nbsp&nbsp&nbsp&nbsp&nbsp&nbspMILESTONE_TRAINERS<br/>Represents trainers for the stages."] {
		serial id "PK"
        INTEGER stage_id "REFERENCES milestones(id)"
		VARCHAR(100) trainer_name  "NOT NULL, -- 'Brock', 'Camper Liam'"
        BOOLEAN is_major_boss  "DEFAULT FALSE"
        VARCHAR(100) condition  "NULLABLE"
	}
	MILESTONES_TEAM["&nbsp&nbsp&nbsp&nbsp&nbsp&nbsp&nbsp&nbsp&nbspMILESTONE_TEAMS<br/>Represents teams for the trainers."] {
		serial id "PK"
        INTEGER trainer_id  "REFERENCES milestone_trainers(id)"
		VARCHAR(50) pokemon_slug "NOT NULL"
        INTEGER slot_number  "NOT NULL"
        INTEGER level "NOT NULL"
        BOOLEAN is_ace  "DEFAULT FALSE"
        TEXT[] moves
        VARCHAR(50) ability
	}

	ENCOUNTER_METHODS["&nbsp&nbsp&nbsp&nbsp&nbspENCOUNTER_METHODS<br/>Ways you can encounter Pokemon"] {
		serial id "PK"
		varchar(50) name "UNIQUE"
		bool is_primary "DEFAULT FALSE"
	}
	ENCOUNTERS["ENCOUNTERS"] {
 		serial id "PK"
        int game_id "FK, NOT NULL REFERENCES games(id)"
        int location_id "FK, NOT NULL REFERENCES locations(id)"
        int location_area_id  "FK, REFERENCES location_areas(id)"
        int pokemon_id  "FK,NOT NULL REFERENCES pokemon(id)"
        varchar(50) method
        int min_level INTEGER
        int max_level INTEGER
        UNIQUE_CONSTRAINT unique_pokemon_encounter_entry "UNIQUE (game_id, location_id, location_area_id, pokemon_id, method)"
	}


