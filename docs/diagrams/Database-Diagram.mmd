	}

	RULESET["&nbsp&nbsp&nbsp&nbsp&nbsp&nbspRULESET<br>&nbsp&nbsp&nbsp&nbsp&nbsp&nbspAll rulesets <br>for different games"] {
		serial id  "PK"  
		string name  ""  
		text description  ""  
		bool is_official  ""  
	}

	REGIONS["REGIONS<br>All regions"] {
		serial id  "PK"  
		varchar(50) name  "UNIQUE NOT NULL"  
	}

	GAME_METADATA["GAME_METADATA<br>&nbsp&nbspContains specific <br/>&nbsp data about games"] {
		int game_id  "PK"  
